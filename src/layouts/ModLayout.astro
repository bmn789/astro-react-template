---
import Template from "./Template.astro";

interface Props {
    title?: string;
}

const { title = "Moderator Panel" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Template>
    <div class="min-h-screen bg-gray-50">
        <!-- Header -->
        <header
            class="bg-white border-b border-gray-200 sticky top-0 z-40 shadow-sm"
        >
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">
                    <!-- Logo/Brand -->
                    <div class="flex items-center">
                        <h1 class="text-xl font-bold text-gray-900">
                            Moderator Panel
                        </h1>
                    </div>

                    <!-- Navigation Links -->
                    <nav class="flex items-center gap-1">
                        <a
                            href="/moderator/users"
                            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                                currentPath === "/moderator/users"
                                    ? "bg-blue-50 text-blue-700"
                                    : "text-gray-600 hover:bg-gray-100 hover:text-gray-900"
                            }`}
                        >
                            Users
                        </a>
                        <a
                            href="/moderator/rooms"
                            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                                currentPath === "/moderator/rooms"
                                    ? "bg-blue-50 text-blue-700"
                                    : "text-gray-600 hover:bg-gray-100 hover:text-gray-900"
                            }`}
                        >
                            Rooms
                        </a>
                        <a
                            href="/moderator/updates"
                            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                                currentPath === "/moderator/updates"
                                    ? "bg-blue-50 text-blue-700"
                                    : "text-gray-600 hover:bg-gray-100 hover:text-gray-900"
                            }`}
                        >
                            Updates
                        </a>
                    </nav>

                    <!-- User Menu (Optional) -->
                    <div class="flex items-center gap-2">
                        <button
                            class="p-2 text-gray-600 hover:bg-gray-100 rounded-lg transition-colors"
                            title="Settings"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                                ></path>
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="h-[calc(100vh-4rem)]">
            <slot />
        </main>
    </div>
</Template>
